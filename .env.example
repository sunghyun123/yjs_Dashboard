PROJECT_NAME=yjs_Dashboard
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=sqlite:///schedule.db

# 카카오 로그인 (카카오 개발자 콘솔의 REST API 키 / 리다이렉트 URI와 동일해야 함)
# 리다이렉트 URI 예: https://your-domain.example/api/auth/kakao/callback
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
# 카카오맵 JavaScript 키 (홈 화면 지도 SDK용 — 도메인 제한이 걸린 공개 키)
# 카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키 > JavaScript 키
KAKAO_MAP_JS_KEY=

# 기상청 API허브(apihub.kma.go.kr) 인증키 — 현장 날씨 위젯
# apihub 가입 후 "단기예보 조회서비스" 활용신청 필요. 격자좌표 기본값은 안양(59,123)
WEATHER_KMA_AUTH_KEY=
# WEATHER_GRID_NX=59
# WEATHER_GRID_NY=123
# WEATHER_CITY_NAME=안양
# 허용 사용자 목록 JSON (기본: 프로젝트 루트의 kakao_whitelist.json)
# KAKAO_WHITELIST_PATH=kakao_whitelist.json

# HTTPS(Caddy/Nginx 등) 뒤에서만 true — 로컬 http:// 테스트 시 false
COOKIE_SECURE=false
# 운영에서 http를 https로 강제 리다이렉트하려면 true
FORCE_HTTPS_REDIRECT=false

# External access settings
HOST=0.0.0.0
PORT=8000

# Comma-separated values
# - Local/LAN only: http://192.168.0.10:8000
# - Public domain example: https://your-domain.example
ALLOWED_ORIGINS=*
ALLOWED_HOSTS=*

# ===== 배포 예시(주석 해제해서 사용) =====
# COOKIE_SECURE=true
# FORCE_HTTPS_REDIRECT=true
# ALLOWED_ORIGINS=https://your-domain.example
# ALLOWED_HOSTS=your-domain.example,www.your-domain.example

# ERP monthly KPI proxy
ERP_MONTHLY_KPI_URL=https://erp.yjsboard.com/api/kpi/monthly-performance
# ERP 자재 요약 proxy (같은 호스트·같은 DASHBOARD_API_KEY, 경로만 다름)
ERP_MATERIALS_URL=https://erp.yjsboard.com/api/materials/summary
ERP_DASHBOARD_API_KEY=
