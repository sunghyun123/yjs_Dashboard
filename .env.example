PROJECT_NAME=yjs_Dashboard
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=sqlite:///schedule.db

# 최초 빈 DB일 때 생성되는 관리자(admin) 비밀번호. 배포 시 강한 값으로 변경.
INITIAL_ADMIN_PASSWORD=change_me_strong_password

# 공개 URL 배포 시 false 권장 (API 무인 가입 차단)
SIGNUP_ENABLED=true

# HTTPS(Caddy/Nginx 등) 뒤에서만 true — 로컬 http:// 테스트 시 false
COOKIE_SECURE=false

# External access settings
HOST=0.0.0.0
PORT=8000

# Comma-separated values
# - Local/LAN only: http://192.168.0.10:8000
# - Public domain example: https://your-domain.example
ALLOWED_ORIGINS=*
ALLOWED_HOSTS=*
