# =============================================================================
# 환경 변수 예시 파일
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해 이름을 `.env` 로 저장합니다. (Git에는 올리지 마세요.)
#   2) 아래 [로컬 개발·테스트] 블록을 채워 PC에서 실행합니다.
#   3) 서버에 배포할 때는 [운영 배포] 블록을 참고해 값을 바꿉니다.
# =============================================================================


# =============================================================================
# [공통] 반드시 채울 값 (로컬·운영 모두)
# =============================================================================

PROJECT_NAME=yjs_Dashboard

# Google Gemini (문서 추출·채팅 일정 등). https://aistudio.google.com/apikey 등에서 발급
GEMINI_API_KEY=AIzaSyCOJqjPDYB8dgMPfhCvu8fkMIVMYQl6Yco

# SQLite DB 파일 (프로젝트 루트 기준 상대 경로 권장)
#   로컬: 아래처럼 두면 루트에 schedule.db 생성
DATABASE_URL=sqlite:///schedule.db



# =============================================================================
# [로컬 개발·테스트] PC에서 uvicorn 띄울 때 권장 값
# =============================================================================


HOST=0.0.0.0
PORT=8000

COOKIE_SECURE=false
FORCE_HTTPS_REDIRECT=false

ALLOWED_ORIGINS=*
ALLOWED_HOSTS=*

# 카카오 로그인 (로컬 테스트)
# - 카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키: REST API 키
# - Redirect URI: 예) http://127.0.0.1:8000/api/auth/kakao/callback  (포트·호스트는 실제와 동일)
KAKAO_REST_API_KEY=66d566eacccfad600cd755c47af71640
KAKAO_CLIENT_SECRET=QzxhXAvdmPgWPqxHVovLqtLuZamThrvr
KAKAO_REDIRECT_URI=http://127.0.0.1:8000/api/auth/kakao/callback

# 허용 카카오 사용자 JSON (기본: 프로젝트 루트 kakao_whitelist.json)
# KAKAO_WHITELIST_PATH=kakao_whitelist.json

# 문서 템플릿(공사 일정 계획서 등). 기본은 레포 안 document_templates
# DOCUMENT_TEMPLATES_DIR=document_templates

# 로컬 PC에서만: 한글 생성기 등 exe 실행 API. 비우면 해당 API는 503
# LOCAL_APPS_ROOT=C:\YJS\local_apps
# LOCAL_APP_HANGUL=HangulGenerator.exe
# LOCAL_APP_ERP=ERP.exe


# =============================================================================
# [운영 배포] HTTPS(Caddy/Nginx 등) 뒤에 올릴 때
# =============================================================================
# 아래는 예시입니다. 로컬에서 그대로 두고, 서버의 `.env` 에만 맞게 수정하세요.
#
# COOKIE_SECURE=true
# FORCE_HTTPS_REDIRECT=false
#
# 실제 도메인만 허용 (쉼표로 여러 개)
# ALLOWED_ORIGINS=https://www.yjsboard.com,https://yjsboard.com
# ALLOWED_HOSTS=yjsboard.com,www.yjsboard.com


# 카카오 (콘솔·.env·실제 접속 URL이 서로 일치해야 함)
# KAKAO_REST_API_KEY=92da227eedee04661469dcd770f508d9
# KAKAO_CLIENT_SECRET=S9Qm6Xqpw6ogjP6fejMjZbqA7uEmSarT
# KAKAO_REDIRECT_URI=https://www.yjsboard.com/api/auth/kakao/callback



# 외출·복귀 시각 자동 처리에 쓰는 타임존(기본: 한국). 서버가 UTC여도 until_time과 맞게 비교합니다.
# APP_TIMEZONE=Asia/Seoul


# =============================================================================
# 메모
# -----------------------------------------------------------------------------
# - 운영에서 COOKIE_SECURE=true 인데 브라우저가 http 로 접속하면 로그인 쿠키가
#   저장되지 않습니다. 리버스 프록시 뒤에서는 X-Forwarded-Proto 등으로 HTTPS를 맞춥니다.
# - 예전 .env 에 있던 알 수 없는 키는 무시됩니다(extra=ignore).
# =============================================================================
